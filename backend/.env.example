# =============================================================================
# Template for backend/.env — copy to backend/.env and fill in real values.
# backend/.env is gitignored and sourced by deploy.sh at deploy time.
# =============================================================================
# Single-quote any value containing $ @ # so bash does not expand it.

# AES-256 key for at-rest field encryption (OprfSeed, TotpSecret, mail secrets…).
ENCRYPTION_FIELD_KEY="<64-hex-chars>"

# PostgreSQL connection string for the production database.
PG_CONNECTION_STRING='Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<password>'

# Brevo SMTP (built-in system mail: login codes, verification links).
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_LOGIN="<brevo-smtp-login>"
BREVO_SMTP_PASSWORD="<brevo-smtp-key>"
BREVO_FROM_EMAIL="<from-address>"
